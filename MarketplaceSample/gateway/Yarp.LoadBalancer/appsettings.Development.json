{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LoadBalancer": {
    "RouteId": "marketplace-route",
    "ClusterId": "marketplace-cluster",
    "RoutePath": "/marketplace/{**catch-all}",
    "PathPattern": "{**catch-all}",
    "LoadBalancingPolicy": "RoundRobin",
    "LivenessPath": "/health/live",
    "ReadinessPath": "/health/ready",
    "ProbeIntervalSeconds": 5,
    "ProbeTimeoutSeconds": 2,
    "HealthyThreshold": 1,
    "UnhealthyThreshold": 2,
    "Destinations": [
      {
        "Id": "destination1",
        "Address": "http://marketplacesample.api1:8080/"
      },
      {
        "Id": "destination2",
        "Address": "http://marketplacesample.api2:8080/"
      },
      {
        "Id": "destination3",
        "Address": "http://marketplacesample.api3:8080/"
      }
    ]
  }
}


