{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "marketplace-route": {
        "ClusterId": "marketplace-cluster",
        "Match": {
          "Path": "/marketplace/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "marketplace-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "destination1": {
            "Address": "http://marketplacesample.api1:8080/"
          },
          "destination2": {
            "Address": "http://marketplacesample.api2:8080/"
          },
          "destination3": {
            "Address": "http://marketplacesample.api3:8080/"
          }
        }
      }
    }
  }
}
